#!/bin/bash
# Stop hook: extract and format tables/diagrams from the last Claude response.
# Saves cleaned output to ~/.claude/clean-output/latest.md
# Copies to clipboard if available.

set -euo pipefail

# Read hook input from stdin
HOOK_INPUT=$(cat)

# Get transcript path from environment or hook input
TRANSCRIPT_PATH="${TRANSCRIPT_PATH:-}"
if [[ -z "$TRANSCRIPT_PATH" ]]; then
  # Try to extract from hook input JSON
  if command -v jq &>/dev/null; then
    TRANSCRIPT_PATH=$(echo "$HOOK_INPUT" | jq -r '.transcript_path // empty' 2>/dev/null || true)
  fi
fi

if [[ -z "$TRANSCRIPT_PATH" || ! -f "$TRANSCRIPT_PATH" ]]; then
  # No transcript available — exit silently
  exit 0
fi

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
LIB_DIR="$PLUGIN_DIR/lib"

# Read config values
AUTO_FORMAT=$(python3 "$LIB_DIR/config.py" --get autoFormat 2>/dev/null || echo "true")
CLIPBOARD=$(python3 "$LIB_DIR/config.py" --get clipboard 2>/dev/null || echo "true")
UNICODE_DIAGRAMS=$(python3 "$LIB_DIR/config.py" --get unicodeDiagrams 2>/dev/null || echo "false")
SAVE_PATH=$(python3 "$LIB_DIR/config.py" --get savePath 2>/dev/null || echo "$HOME/.claude/clean-output/latest.md")

# Skip if auto-format disabled
if [[ "$AUTO_FORMAT" == "false" ]]; then
  echo '{}'
  exit 0
fi

# Run extractor
EXTRA_ARGS=""
if [[ "$UNICODE_DIAGRAMS" == "true" ]]; then
  EXTRA_ARGS="--normalize-chars"
fi
result=$(python3 "$LIB_DIR/extract.py" "$TRANSCRIPT_PATH" $EXTRA_ARGS 2>/dev/null || true)

if [[ -z "$result" ]]; then
  # Nothing to format
  exit 0
fi

# Save to file
SAVE_DIR=$(dirname "${SAVE_PATH/#\~/$HOME}")
SAVE_FILE="${SAVE_PATH/#\~/$HOME}"
mkdir -p "$SAVE_DIR"
echo "$result" > "$SAVE_FILE"

# Copy to clipboard (best effort)
if [[ "$CLIPBOARD" == "true" ]]; then
  if command -v pbcopy &>/dev/null; then
    echo "$result" | pbcopy
  elif command -v xclip &>/dev/null; then
    echo "$result" | xclip -selection clipboard
  elif command -v xsel &>/dev/null; then
    echo "$result" | xsel --clipboard --input
  fi
fi

# Return empty JSON to allow stop (don't block)
echo '{}'
exit 0
